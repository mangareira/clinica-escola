{
  "name": "clinica-escola",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev:backend": "npm --workspace backend run start:dev",
