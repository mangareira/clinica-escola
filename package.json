{
  "name": "clinica-escola",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev": "run-p dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run start:dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build && npm --workspace frontend run build"
  },
  "dependencies": {
    "@nestjs/jwt": "^11.0.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
